enum QuestionnaireType {
  QUIZ
  SURVEY

  @@map("questionnaireType")
}

enum QuestionnaireQuestionType {
  TEXT
  SINGLE_SELECT
  MULTI_SELECT
  TRUE_FALSE
  RATING
  SCALE

  @@map("questionnaireQuestionType")
}

model Questionnaire {
  id          String            @id @default(uuid())
  type        QuestionnaireType
  eventId     String?
  title       String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  event     Event?                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions QuestionnaireQuestion[]
  responses QuestionnaireResponse[]

  @@map("questionnaire")
}

model QuestionnaireQuestion {
  id              String                    @id @default(uuid())
  questionnaireId String
  type            QuestionnaireQuestionType
  prompt          String
  isRequired      Boolean
  explanation     String?
  score           Int?
  order           Int

  // TRUE_FALSE
  trueFalseAnswer Boolean?
  trueLabel       String?
  falseLabel      String?

  // RATING (fixed 1-5)
  ratingTarget Int?

  // SCALE
  scaleMin      Int?
  scaleMax      Int?
  scaleTarget   Int?
  scaleMinLabel String?
  scaleMaxLabel String?

  questionnaire Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  options       QuestionnaireOption[] // SINGLE_SELECT and MULTI_SELECT only
  answers       QuestionnaireAnswer[]

  @@map("questionnaireQuestion")
}

model QuestionnaireOption {
  id         String  @id @default(uuid())
  questionId String
  label      String
  value      String
  isCorrect  Boolean @default(false)
  score      Int     @default(0)
  order      Int

  question      QuestionnaireQuestion           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerOptions QuestionnaireOptionsOnAnswers[]

  @@unique([questionId, value])
  @@map("questionnaireOption")
}

model QuestionnaireResponse {
  id              String   @id @default(uuid())
  questionnaireId String
  userId          String
  total           Int?
  isAnonymous     Boolean?
  submittedAt     DateTime @default(now())

  questionnaire Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers       QuestionnaireAnswer[]

  @@map("questionnaireResponse")
}

model QuestionnaireAnswer {
  id         String @id @default(uuid())
  questionId String
  responseId String

  // Answer value
  valueString  String? // Text answer
  valueInt     Int? // Scale & rating answer
  valueBoolean Boolean? // True/false answer
  valueOptions QuestionnaireOptionsOnAnswers[] // Single & multi select answers

  // Scoring snapshot
  isCorrect Boolean?
  score     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question QuestionnaireQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response QuestionnaireResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@map("questionnaireAnswer")
}

model QuestionnaireOptionsOnAnswers {
  answerId String
  optionId String

  answer QuestionnaireAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  option QuestionnaireOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([answerId, optionId])
  @@map("questionnaireOptionsOnAnswers")
}
