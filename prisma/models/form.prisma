enum FormType {
  QUIZ
  SURVEY

  @@map("formType")
}

enum FormQuestionType {
  RATING
  YES_NO
  TEXT
  MULTICHOICE
  CHECKBOX
  SCALE
}

model Form {
  id          String   @id @default(uuid())
  type        FormType
  eventId     String?
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions FormQuestion[]
  responses FormResponse[]

  @@map("form")
}

model FormQuestion {
  id           String           @id @default(uuid())
  formId       String
  type         FormQuestionType
  questionText String
  isRequired   Boolean
  explanation  String?
  score        Int?
  quizConfig   Json?
  orderIndex   Int

  form    Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  options FormOption[]
  answers FormAnswer[]

  @@map("formQuestion")
}

model FormOption {
  id         String @id @default(uuid())
  questionId String
  label      String
  value      String
  orderIndex Int

  question FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("formOption")
}

model FormResponse {
  id          String   @id @default(uuid())
  formId      String
  userId      String
  total       Int
  isAnonymous Boolean?
  submittedAt DateTime @default(now())

  form    Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers FormAnswer[]

  @@map("formResponse")
}

model FormAnswer {
  id         String @id @default(uuid())
  questionId String
  responseId String

  // Answer value
  valueString  String?
  valueInt     Int?
  valueBoolean Boolean?
  valueJson    Json?

  // Scoring snapshot
  isCorrect Boolean?
  score     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime

  question FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@map("formAnswer")
}
