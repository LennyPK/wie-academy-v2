enum FormType {
  QUIZ
  SURVEY

  @@map("formType")
}

enum FormQuestionType {
  TEXT
  SINGLE_SELECT
  MULTI_SELECT
  TRUE_FALSE
  RATING
  SCALE

  @@map("formQuestionType")
}

enum GradingStatus {
  PENDING
  COMPLETE
  NA

  @@map("gradingStatus")
}

model Form {
  id          String   @id @default(uuid())
  type        FormType
  eventId     String?
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions   FormQuestion[]
  responses   FormResponse[]
  formAnswers FormAnswer[]

  @@map("form")
}

model FormQuestion {
  id          String           @id @default(uuid())
  formId      String
  type        FormQuestionType
  prompt      String
  isRequired  Boolean
  explanation String?
  score       Int?
  // quizConfig  Json?
  order       Int

  // TRUE_FALSE
  correctAnswer Boolean?
  trueLabel     String?
  falseLabel    String?

  // RATING (fixed 1-5)
  ratingTarget Int?

  // SCALE
  scaleMin      Int?
  scaleMax      Int?
  scaleTarget   Int?
  scaleMinLabel String?
  scaleMaxLabel String?

  form    Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  options FormOption[] // SINGLE_SELECT and MULTI_SELECT only
  answers FormAnswer[]

  @@map("formQuestion")
}

model FormOption {
  id         String  @id @default(uuid())
  questionId String
  label      String
  value      String
  isCorrect  Boolean @default(false)
  score      Int     @default(0)
  order      Int

  question      FormQuestion           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerOptions FormOptionsOnAnswers[]

  @@map("formOption")
}

model FormResponse {
  id          String   @id @default(uuid())
  formId      String
  userId      String
  total       Int?
  isAnonymous Boolean?
  submittedAt DateTime @default(now())

  form    Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers FormAnswer[]

  @@map("formResponse")
}

model FormAnswer {
  id         String @id @default(uuid())
  questionId String
  responseId String

  // Answer value
  valueString  String?
  valueInt     Int?
  valueBoolean Boolean?
  valueJson    Json?

  // Scoring snapshot
  isCorrect Boolean?
  score     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime

  question             FormQuestion           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response             FormResponse           @relation(fields: [responseId], references: [id], onDelete: Cascade)
  selectedOptions      Form                   @relation(fields: [formId], references: [id])
  formId               String
  formOptionsOnAnswers FormOptionsOnAnswers[]

  @@map("formAnswer")
}

model FormOptionsOnAnswers {
  answerId String
  optionId String

  answer FormAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  option FormOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([answerId, optionId])
  @@map("formOptionsOnAnswers")
}
