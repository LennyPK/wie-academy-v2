# Copy this file to `.env` and fill in the values.
#   cp .env.example .env

# --- Database (PostgreSQL) -------------------------------------------------
# Prisma + node-postgres connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/wie_academy"

# --- Auth (better-auth) ----------------------------------------------------
# Secret used to sign sessions/tokens. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-generated-secret"
# Base URL the auth client points at. Optional in local dev (defaults to the
# current origin); set this in deployed environments.
# BETTER_AUTH_URL="http://localhost:3000"

# Canonical site URL, used for metadata in production builds.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email (Resend) --------------------------------------------------------
# Used for verification and password-reset emails.
RESEND_API_KEY="re_your_api_key"
EMAIL_SENDER_NAME="WiE Academy"
EMAIL_SENDER_ADDRESS="no-reply@yourdomain.com"
# Shown as the "Contact Support" address on the approval screens.
EMAIL_SUPPORT_ADDRESS="support@yourdomain.com"
